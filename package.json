{
	"name": "nextjs-onboard",
	"version": "1.0.0",
	"description": "A Next.js onboarding project",
	"type": "module",
	"engines": {
		"node": ">=22.x"
	},
	"dependencies": {
		"cookie-parser": "^1.4.7",
		"express": "^5.2.1",
		"next": "^16.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"ts": "^0.2.2",
		"typescript-transform-paths": "^3.5.6"
	},
	"scripts": {
		"web-dev": "NODE_OPTIONS='--inspect' next dev",
		"web-build": "next build",
		"web-start": "next start",
		"api-prepare": "ts-patch install -s",
		"api-dev": "NODE_OPTIONS='--inspect' tsx watch server/main.ts",
		"api-build": "tspc -p server/tsconfig.json",
		"api-start": "node server/build/main.js",
		"lint": "eslint",
		"lint:fix": "eslint --fix"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/node": "25.3.0",
		"@types/react": "19.2.14",
		"eslint": "^9.39.1",
		"eslint-config-next": "^16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"tailwindcss": "^4.2.0",
		"ts-patch": "^3.3.0",
		"tsx": "^4.21.0",
		"typescript": "5.9.3"
	}
}
